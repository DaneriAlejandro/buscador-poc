# BigQuery
BIGQUERY_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
BIGQUERY_DATASET=ds_bidcom
BIGQUERY_TABLE=posts
# Optional: override the default SELECT * query
# BIGQUERY_QUERY=SELECT id, title, description FROM `project.dataset.table` WHERE active = true

# Meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=api-key-bidcom-products
MEILISEARCH_INDEX=productos-BQ
MEILISEARCH_PRIMARY_KEY=ID
MEILISEARCH_SORT_FIELD=orden_web
# Optional: comma-separated override (defaults to title, sku, ean, description, brand, etc.)
# MEILISEARCH_SEARCHABLE_ATTRIBUTES=post_title,codigo_aguila,ean,descripcion_producto
# MEILISEARCH_DISPLAYED_ATTRIBUTES=post_title,imagen_calada,precio,marca,codigo_aguila

# Sync
SYNC_BATCH_SIZE=1000
SYNC_DELETE_STALE=true
# Optional: run sync on a loop (minutes). Also: node src/index.js --interval 10
# SYNC_INTERVAL_MINUTES=10

# Search UI (npm run web)
# SEARCH_WEB_PORT=3000
